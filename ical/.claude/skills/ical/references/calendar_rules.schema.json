{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ical calendar rules memory",
  "type": "object",
  "additionalProperties": false,
  "required": ["calendar_rules"],
  "properties": {
    "calendar_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "match", "behavior"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "match": {
            "type": "string",
            "minLength": 1
          },
          "behavior": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
